{
  "name": "finsight",
  "version": "1.0.0",
  "description": "Accessible banking app for blind and low-vision users",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "wizard:dashboard": "node wizard-dashboard/server.js",
    "wizard:android-usb": "bash scripts/wizard-android-usb.sh"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-screen-orientation": "~9.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/plugin-transform-optional-chaining": "^7.28.6",
    "@babel/plugin-transform-shorthand-properties": "^7.27.1",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@types/jpeg-js": "^0.3.0",
    "@types/react": "~19.1.10",
    "react-native-dotenv": "^3.4.11",
    "typescript": "^5.3.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/react"
      ]
    }
  },
  "private": true
}
